# Server
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Dependency configuration
# If MySQL is running via docker-compose at repo root, this default works.
DATABASE_URL="mysql://saarthi_user:saarthi_pass@localhost:3306/saarthi_db"
JWT_SECRET=change-this-in-dev
JWT_EXPIRES_IN=7d
MAX_FILE_SIZE_MB=25
UPLOAD_DIR=uploads
FILE_CLEANUP_ENABLED=true
FILE_RETENTION_DAYS=7
FILE_CLEANUP_INTERVAL_MINUTES=60
PINECONE_API_KEY=
PINECONE_INDEX=saarthi-gov-docs

# LLM
ACTIVE_LLM_PROVIDER=gemini
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
